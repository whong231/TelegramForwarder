######### 必填项 #########
# Telegram API 配置 (从 https://my.telegram.org/apps 获取)
# 也可以通过 Web 管理后台 http://localhost:9805/admin/setup 配置
API_ID=
API_HASH=

# 用户账号登录用的手机号 (格式如: +8613812345678)
PHONE_NUMBER=

# Bot Token
BOT_TOKEN=

# 用户ID (从 @userinfobot 获取)
USER_ID=


################ 以下均为可选项 ##################

# 管理员列表(此处填user_id，留空默认上方的USER_ID，多个用户用逗号分隔)
ADMINS=

# Web 管理后台密码 (首次启动自动生成，也可手动设置)
# WEB_ADMIN_PASSWORD=

# bot消息删除时间 (秒),0表示立即删除, -1表示不删除
BOT_MESSAGE_DELETE_TIMEOUT=300

# 是否自动删除用户发送的指令消息 (true/false)
USER_MESSAGE_DELETE_ENABLE=false

# 默认最大媒体文件大小限制（单位：MB）
DEFAULT_MAX_MEDIA_SIZE=15

# 默认时区
DEFAULT_TIMEZONE=Asia/Shanghai

# 自动更新数据库中聊天窗口名字时间 (24小时制)
CHAT_UPDATE_TIME=03:00

# 数据库配置
DATABASE_URL=sqlite:///./db/forward.db


######### 代理设置 (也可通过 Web 管理后台配置) #########
PROXY_ENABLED=false
# 代理类型: socks5 | http
PROXY_TYPE=http
# 示例: 本地 HTTP 代理
PROXY_HOST=192.168.31.30
PROXY_PORT=7890
PROXY_USERNAME=
PROXY_PASSWORD=


######### UI 布局配置 #########
AI_MODELS_PER_PAGE=10
KEYWORDS_PER_PAGE=10
PUSH_CHANNEL_PER_PAGE=10
SUMMARY_TIME_ROWS=10
SUMMARY_TIME_COLS=6
DELAY_TIME_ROWS=10
DELAY_TIME_COLS=6
MEDIA_SIZE_ROWS=10
MEDIA_SIZE_COLS=6
MEDIA_EXTENSIONS_ROWS=10
MEDIA_EXTENSIONS_COLS=6
RULES_PER_PAGE=20


######### AI设置 #########
DEFAULT_AI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_API_BASE=
CLAUDE_API_KEY=
CLAUDE_API_BASE=
GEMINI_API_KEY=
GEMINI_API_BASE=
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=
QWEN_API_KEY=
QWEN_API_BASE=
GROK_API_KEY=
GROK_API_BASE=
DEFAULT_AI_PROMPT=请尊重原意，保持原有格式不变，用简体中文重写下面的内容：
DEFAULT_SUMMARY_PROMPT=请总结以下频道/群组24小时内的消息。
DEFAULT_SUMMARY_TIME=07:00
SUMMARY_BATCH_SIZE=20
SUMMARY_BATCH_DELAY=2


######### RSS配置 #########
RSS_ENABLED=false
RSS_BASE_URL=
RSS_MEDIA_BASE_URL=


######### 扩展内容 #########
UFB_ENABLED=false
UFB_SERVER_URL=
UFB_TOKEN=
